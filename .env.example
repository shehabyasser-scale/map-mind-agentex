# OpenAI API key (used by Nova agent for direct GPT-4o calls)
OPENAI_API_KEY=sk-proj-your-key-here

# AgentEx backend URL (default: http://localhost:5003)
AGENTEX_URL=http://localhost:5003

# AgentEx agent name for Atlas (default: agent-shehab-3)
AGENTEX_AGENT_NAME=agent-shehab-3

# Game server port (default: 4567)
PORT=4567
